# Supabase Configuration
# Create a new project at https://supabase.com and copy your credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Note: Server-side service role key is not required for Version 1
# All database operations use the anonymous key with public RLS policies

# Admin Password
# Used to protect the Admin dashboard. Change this after deployment.
ADMIN_PASSWORD=KWT2026Admin!
